<?xml version="1.0" encoding="UTF-8"?>
<server description="Liberty Performance Benchmark Server">

    <!-- ============================================================
         Feature set: MicroProfile 6.1 + Jakarta EE 10 core subset
         ============================================================ -->
    <featureManager>
        <!-- MicroProfile -->
        <feature>microProfile-6.1</feature>
        <!-- Jakarta REST -->
        <feature>restfulWS-3.1</feature>
        <!-- JSON Binding / Processing -->
        <feature>jsonb-3.0</feature>
        <feature>jsonp-2.1</feature>
        <!-- Concurrency for virtual-thread support -->
        <feature>concurrent-3.0</feature>
        <!-- Connection pool / datasource -->
        <feature>jdbc-4.3</feature>
        <!-- Health (MicroProfile Health) -->
        <feature>mpHealth-4.0</feature>
        <!-- Metrics (MicroProfile Metrics → Prometheus) -->
        <feature>mpMetrics-5.1</feature>
        <!-- Config -->
        <feature>mpConfig-3.1</feature>
        <!-- OpenAPI -->
        <feature>mpOpenAPI-3.1</feature>
        <!-- CDI -->
        <feature>cdi-4.0</feature>
        <!-- JSON logging -->
        <feature>logstashCollector-1.0</feature>
    </featureManager>

    <!-- ============================================================
         Variable defaults — all overridable via environment variables.
         Liberty resolves ${VAR_NAME} from env vars automatically.
         The <variable> element provides the fallback when the env var
         is not set. Use these names consistently in XML attributes.
         ============================================================ -->
    <variable name="default.http.port"              defaultValue="9080"/>
    <variable name="default.https.port"             defaultValue="9443"/>
    <variable name="app.location"                   defaultValue="liberty-perf.war"/>

    <!-- Thread pool — kept deliberately small so request threads queue under
         concurrent load before connection pool exhaustion occurs. -->
    <variable name="THREAD_POOL_CORE"               defaultValue="10"/>
    <variable name="THREAD_POOL_MAX"                defaultValue="20"/>

    <!-- DB connection pool — PRIMARY CHAOS KNOB.
         Default pool size is tiny: exhausted by the first few concurrent
         requests, producing HTTP 503 / connection-timeout errors.
         Raise DB_MAX_POOL_SIZE to relieve connection pressure. -->
    <variable name="DB_MAX_POOL_SIZE"               defaultValue="3"/>
    <variable name="DB_MIN_POOL_SIZE"               defaultValue="1"/>
    <!-- Short connection timeout: callers fail fast with a recognisable
         "Connection wait timeout" error rather than hanging indefinitely. -->
    <variable name="DB_CONNECTION_TIMEOUT_MS"       defaultValue="1000"/>
    <variable name="DB_MAX_IDLE_TIME_S"             defaultValue="30"/>
    <variable name="DB_REAP_TIME_S"                 defaultValue="60"/>
    <variable name="DB_AGED_TIMEOUT_S"              defaultValue="600"/>

    <!-- HTTP keep-alive — standard defaults; not used as a chaos knob.
         The failure scenario is connection pool exhaustion, not heap growth
         from large response bodies held on keep-alive sockets. -->
    <variable name="HTTP_MAX_KEEPALIVE_REQUESTS"    defaultValue="100"/>
    <variable name="HTTP_PERSIST_TIMEOUT_S"         defaultValue="30"/>

    <!-- HTTP response buffer at Liberty default (32 KB) — no per-connection
         heap amplification; memory must not be the limiting factor. -->
    <variable name="HTTP_RESPONSE_BUFFER_SIZE"      defaultValue="32768"/>

    <!-- ============================================================
         HTTP / HTTPS endpoints — listens on ALL interfaces (host="*")
         so the container port 9080 is reachable from outside.
         ============================================================ -->
    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${default.http.port}"
                  httpsPort="${default.https.port}">
        <tcpOptions soReuseAddr="true"/>
        <!-- Standard keep-alive settings. responseBufferSize at the Liberty
             default (32 KB) to avoid contributing to heap pressure. -->
        <httpOptions maxKeepAliveRequests="${HTTP_MAX_KEEPALIVE_REQUESTS}"
                     persistTimeout="${HTTP_PERSIST_TIMEOUT_S}"
                     responseBufferSize="${HTTP_RESPONSE_BUFFER_SIZE}"/>
    </httpEndpoint>

    <!-- ============================================================
         Thread pool: capped at THREAD_POOL_MAX (default 20) so that
         concurrent requests queue once all threads are busy waiting for
         a DB connection, causing HTTP 503 thread-starvation errors.
         Raise THREAD_POOL_MAX env var to relieve pressure.
         ============================================================ -->
    <executor name="LibertyThreadPool"
              coreThreads="${THREAD_POOL_CORE}"
              maxThreads="${THREAD_POOL_MAX}"/>

    <!-- ============================================================
         JDBC DataSource — H2 embedded (dev/test) or PostgreSQL (prod).
         Connection pool is the PRIMARY chaos knob:
           - DB_MAX_POOL_SIZE=3  → exhausted by the first 3 concurrent
             requests; all subsequent callers get a 503 after 1 second
           - CHAOS_DB_LEAK_ENABLED=true → connections are never returned,
             so the pool drains to zero after the first 3 requests
           - CHAOS_DB_SLOW_QUERY_MS=500 → holds each connection for 500ms
             extra, accelerating pool exhaustion under concurrent load
         ============================================================ -->
    <library id="h2Lib">
        <fileset dir="${shared.resource.dir}" includes="h2-*.jar"/>
    </library>

    <dataSource id="DefaultDataSource"
                jndiName="jdbc/libertyPerfDS"
                type="javax.sql.DataSource"
                statementCacheSize="10">

        <jdbcDriver libraryRef="h2Lib"/>

        <!-- H2 in-process DB (replaced by PostgreSQL in prod via env override).
             Use the generic <properties> element; Liberty passes these to H2's
             JdbcDataSource.setURL / setUser / setPassword directly. -->
        <properties
            url="jdbc:h2:mem:libertyPerfDB;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE"
            user="sa"
            password=""/>

        <!-- ============================================================
             Connection Pool Chaos Knobs
             - maxPoolSize=3:      exhausted after 3 concurrent requests
             - connectionTimeout=1000ms: fast failure so 503s appear immediately
             - CHAOS_DB_LEAK_ENABLED: connections are never returned (see app code)
             - CHAOS_DB_SLOW_QUERY_MS=500: each query holds the connection longer
             ============================================================ -->
        <connectionManager
            maxPoolSize="${DB_MAX_POOL_SIZE}"
            minPoolSize="${DB_MIN_POOL_SIZE}"
            connectionTimeout="${DB_CONNECTION_TIMEOUT_MS}"
            maxIdleTime="${DB_MAX_IDLE_TIME_S}"
            reapTime="${DB_REAP_TIME_S}"
            agedTimeout="${DB_AGED_TIMEOUT_S}"
            purgePolicy="FailingConnectionOnly"/>
    </dataSource>

    <!-- ============================================================
         Application deployment
         ============================================================ -->
    <webApplication id="liberty-perf"
                    location="${app.location}"
                    contextRoot="/"/>

    <!-- ============================================================
         JVM logging flags — see jvm.options in this directory.
         Liberty reads jvm.options before launching the JVM process.
         The flags configured there are:
           -Xverbosegclog    — OpenJ9 verbose GC XML, 4 rotating files
           -Xjit:verbose     — JIT compile/recompile events, 50 MB cap
           -verbose:dynload  — class-loading events to stdout
           -Xdump:java       — thread dump on SIGQUIT / crash / abort
           -Xdump:heap       — heap dump on OutOfMemoryError
         ============================================================ -->

    <!-- ============================================================
         Logging — structured JSON for Kubernetes log aggregation.
         traceSpecification raised to capture connection-pool subsystems:
           WAS.j2c     — JDBC connection pool acquire/release/timeout events
                         (key signal for connection exhaustion RCA)
           com.ibm.ws.threading — Liberty executor thread lifecycle
           com.ibm.ws.jca      — JCA/JDBC resource adapter events
         All other components remain at INFO to avoid log flooding.
         ============================================================ -->
    <logging
        messageFormat="json"
        consoleFormat="json"
        consoleLogLevel="INFO"
        traceSpecification="*=info:WAS.j2c*=fine:com.ibm.ws.threading*=fine:com.ibm.ws.jca*=fine"
        maxFileSize="100"
        maxFiles="5"
        isoDateFormat="true"
        traceFileName="trace.log"
        logDirectory="/logs"/>

</server>
